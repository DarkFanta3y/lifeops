# === LLM 配置 (前缀: LLM_) ===
# 必填：OpenAI 或兼容 API 的密钥
LLM_API_KEY=
# 模型名称（默认: gpt-4o）
LLM_MODEL=gpt-4o
# API 端点（默认: https://api.openai.com/v1）
LLM_API_BASE=https://api.openai.com/v1
# 最大生成 token 数（默认: 4096）
LLM_MAX_TOKENS=4096
# 生成温度 0.0~2.0（默认: 0.7）
LLM_TEMPERATURE=0.7

# === 上下文配置 (前缀: LIFEOPS_CONTEXT_) ===
# 上下文窗口最大 token 数（默认: 200000）
LIFEOPS_CONTEXT_MAX_CONTEXT_TOKENS=200000
# L1 始终在上下文中的预算比例（默认: 0.10）
LIFEOPS_CONTEXT_L1_BUDGET_RATIO=0.10
# L2 按需加载的预算比例（默认: 0.60）
LIFEOPS_CONTEXT_L2_BUDGET_RATIO=0.60
# L3 溢出层的预算比例（默认: 0.20）
LIFEOPS_CONTEXT_L3_BUDGET_RATIO=0.20
# 保留比例（默认: 0.10）
LIFEOPS_CONTEXT_RESERVE_RATIO=0.10

# === Skill 配置 (前缀: LIFEOPS_SKILLS_) ===
# 是否启用 Skill 系统（默认: true）
LIFEOPS_SKILLS_ENABLED=true
# 项目级 Skill 目录（默认: .lifeops/skills）
LIFEOPS_SKILLS_PROJECT_DIR=.lifeops/skills
# 用户级 Skill 目录（默认: ~/.lifeops/skills）
LIFEOPS_SKILLS_USER_DIR=~/.lifeops/skills
# 是否启用 LLM 隐式匹配 Skill（默认: true）
LIFEOPS_SKILLS_IMPLICIT_MATCH_ENABLED=true
# 单轮最多激活的 Skill 数量（默认: 3）
LIFEOPS_SKILLS_MAX_ACTIVE=3

# === 全局配置 (前缀: LIFEOPS_) ===
# 调试模式（默认: false）
LIFEOPS_DEBUG=false
# 日志级别（默认: INFO）
LIFEOPS_LOG_LEVEL=INFO

# === MCP 配置 (前缀: LIFEOPS_MCP_) ===
# 是否启用 MCP 工具（默认: true）
LIFEOPS_MCP_ENABLED=true
# MCP Server JSON 配置（默认: 空，不自动加载）
LIFEOPS_MCP_SERVERS=

# === GitHub MCP Server 配置 ===
# 使用 GitHub MCP 预设时必填
GITHUB_PERSONAL_ACCESS_TOKEN=

# === Google Workspace MCP Server 配置 ===
# 使用 Google Workspace MCP 预设时必填：Google OAuth Client ID
GOOGLE_OAUTH_CLIENT_ID=
# 可选：Google OAuth Client Secret
GOOGLE_OAUTH_CLIENT_SECRET=
# 可选：本地开发 HTTP OAuth 回调时设置为 1
OAUTHLIB_INSECURE_TRANSPORT=
# 可选：OAuth 凭据缓存目录
GOOGLE_MCP_CREDENTIALS_DIR=
# 默认只启用 Gmail 草稿权限；如需真实发送，显式改为 gmail:send
LIFEOPS_GOOGLE_WORKSPACE_MCP_PERMISSIONS=gmail:drafts
# Google Workspace MCP 工具层级（默认: core）
LIFEOPS_GOOGLE_WORKSPACE_MCP_TOOL_TIER=core

# === SerpApi 配置 (前缀: SERPAPI_) ===
# SerpApi 搜索 API 密钥（必填：用于网络搜索工具）
SERPAPI_API_KEY=
